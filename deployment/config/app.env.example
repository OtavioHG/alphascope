APP_ENV=production
LIVE_TRADING_MODE=paper
LIVE_TRADING_ENABLED=false
ENABLE_TELEGRAM_ALERTS=false
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLL_SECONDS=1
ENABLE_CONTINUOUS_PIPELINE=true
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/alphascope
REDIS_URL=redis://redis:6379/0

# Multi-Agent External LLMs
# =========================
LLM_ENABLE_EXTERNAL=true
LLM_FORCE_LOCAL_FALLBACK=false
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=2
OPENROUTER_API_KEY=your_openrouter_api_key_here
MARKET_AGENT_MODEL=nvidia/nemotron-3-super-120b-a12b:free
MARKET_AGENT_FALLBACK_MODEL=local-market-heuristic
NEWS_AGENT_MODEL=openai/gpt-oss-120b:free
NEWS_AGENT_FALLBACK_MODEL=local-news-heuristic
RISK_AGENT_MODEL=minimax/minimax-m2.5:free
RISK_AGENT_FALLBACK_MODEL=local-risk-heuristic
EXECUTION_AGENT_MODEL=minimax/minimax-m2.5:free
EXECUTION_AGENT_FALLBACK_MODEL=local-execution-policy
MEMORY_AGENT_MODEL=arcee-ai/trinity-large-preview:free
MEMORY_AGENT_FALLBACK_MODEL=local-memory-engine
MULTI_AGENT_BUY_THRESHOLD=0.66
MULTI_AGENT_SELL_THRESHOLD=0.34
MULTI_AGENT_TRAIN_ON_RUNTIME_CYCLE=true
MULTI_AGENT_APPLY_DYNAMIC_THRESHOLDS_ON_RUNTIME_CYCLE=true
