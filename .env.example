APP_NAME=AlphaScope
APP_ENV=production
LOG_LEVEL=INFO
LOG_FORMAT=json
ECHO_SQL=false

DATA_DIR=data
LOG_DIR=logs
SQLITE_PATH=data/alphascope.db
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/alphascope
REDIS_URL=redis://localhost:6379/0
KAGGLE_DATA_DIR=data/external/kaggle
HF_DATASETS_DIR=data/external/huggingface
LARGE_DATA_FORMAT=parquet
MARKET_DATASET_PATH=data/processed/market_training_dataset.parquet
NEWS_DATASET_PATH=data/news/news_training_dataset.parquet

BINANCE_BASE_URL=https://api.binance.com
BINANCE_TESTNET_BASE_URL=https://testnet.binance.vision/api
CRYPTOCOMPARE_BASE_URL=https://min-api.cryptocompare.com
COINGECKO_BASE_URL=https://api.coingecko.com
COINMARKETCAP_BASE_URL=https://pro-api.coinmarketcap.com
GDELT_BASE_URL=https://api.gdeltproject.org
FEAR_GREED_API=https://api.alternative.me/fng/

BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
COINGECKO_API_KEY=your_coingecko_api_key_here
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here
API_KEY_SECRET=change_me_before_production

REQUEST_TIMEOUT=30
REQUEST_RETRIES=5

ENABLE_BINANCE=true
ENABLE_CRYPTOCOMPARE=true
ENABLE_COINGECKO=true
ENABLE_COINMARKETCAP=false
ENABLE_FEAR_GREED=true
ENABLE_GDELT=true
PRIMARY_MARKET_SOURCE=binance
FALLBACK_SOURCES=coingecko,coinmarketcap
EXTERNAL_MARKET_PAGE_SIZE=250
EXTERNAL_MARKET_MAX_PAGES=2

SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,LINKUSDT,BNBUSDT,ADAUSDT,DOGEUSDT,AVAXUSDT,TRXUSDT
DEFAULT_INTERVAL=1h
DEFAULT_CANDLE_LIMIT=1000
AUTO_UNIVERSE_TOP_N=200
AUTO_UNIVERSE_QUOTE_ASSET=USDT
AUTO_UNIVERSE_MIN_VOLUME=10000000

SHORT_WINDOW=9
LONG_WINDOW=21
RSI_WINDOW=14
VOLATILITY_WINDOW=20
VOLUME_WINDOW=20
MOMENTUM_WINDOW=5

RANKING_MODE=hybrid_with_news
RANKING_ML_WEIGHT=0.60
RANKING_HEURISTIC_WEIGHT=0.25
RANKING_NEWS_WEIGHT=0.15
RANKING_NEWS_LOOKBACK_HOURS=72
MARKET_TARGET_NAME=up_move_target
TARGET_HORIZON_BARS=8
TARGET_THRESHOLD_PCT=0.015
TRAINING_TRAIN_FRACTION=0.85

RANK_BUY_THRESHOLD=0.42
RANK_SELL_THRESHOLD=0.24
MIN_CONFIDENCE_SCORE=0.42
MIN_MODEL_CONFIDENCE=0.55

NLP_MODEL_NAME=ProsusAI/finbert
NLP_TOPIC_MODEL_NAME=facebook/bart-large-mnli
HUGGINGFACE_SENTIMENT_DATASET=financial_phrasebank
OPTUNA_TRIALS=25

BACKTEST_INITIAL_CASH=10000
BACKTEST_FEE_RATE=0.001
PAPER_INITIAL_CASH=10000
PAPER_MAX_POSITIONS=3
PAPER_POSITION_SIZE=0.33
PAPER_FEE_RATE=0.001

LIVE_TRADING_ENABLED=false
LIVE_TRADING_MODE=paper
LIVE_MARKET_TYPE=spot
LIVE_KILL_SWITCH_ENABLED=true
LIVE_EMERGENCY_STOP=false
LIVE_ALLOW_LIVE_MODE=false
LIVE_REQUIRE_EXPLICIT_CONFIRMATION=true
LIVE_ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

MAX_OPEN_TRADES=2
MAX_POSITION_SIZE_PCT=0.01
MAX_ACCOUNT_EXPOSURE_PCT=0.05
MAX_DAILY_LOSS_PCT=0.005
MAX_DRAWDOWN_ALLOWED=0.20

MIN_BALANCE_REQUIRED=10
MIN_NOTIONAL_USDT=10
DEFAULT_ORDER_USD=10
MIN_POSITION_USD=10
MAX_POSITION_USD=15
MIN_TRADE_VALUE=10
ORDER_SIZE_USDT=10

STOP_LOSS_PCT=0.015
TAKE_PROFIT_PCT=0.03
TRAILING_STOP_PCT=0.01

ENABLE_DUPLICATE_POSITION_BLOCK=true
ENABLE_ORPHAN_POSITION_DETECTION=true
ENABLE_POSITION_TIMEOUT=true
MAX_POSITION_DURATION_HOURS=8
AUTO_SYNC_ACCOUNT=true
AUTO_SYNC_INTERVAL_SECONDS=30
ENABLE_ORDER_RETRY=true
MAX_ORDER_RETRIES=3
ENABLE_COOLDOWN=true
COOLDOWN_MINUTES_PER_SYMBOL=30
ENABLE_PARTIAL_TAKE_PROFIT=true
PARTIAL_TAKE_PROFIT_PCT=0.02
PARTIAL_TAKE_PROFIT_SIZE=0.50
ENABLE_BREAK_EVEN=true
BREAK_EVEN_TRIGGER_PCT=0.01
BREAK_EVEN_OFFSET_PCT=0.001
AUTO_CLOSE_ON_API_ERROR=true
AUTO_CLOSE_ON_DAILY_LOSS=true
ENABLE_MARKET_REGIME_FILTER=true
ALLOW_TRADES_IN_SIDEWAYS_MARKET=false
MIN_RELATIVE_VOLUME=1.20
MIN_TREND_STRENGTH=0.60
MIN_BREAKOUT_STRENGTH=0.008
BLOCK_OVERBOUGHT_RSI=true
MAX_BUY_RSI=68
ENABLE_BTC_CONFIRMATION=true
BTC_CONFIRMATION_SYMBOL=BTCUSDT
BTC_CONFIRMATION_MIN_SCORE=0.30
MAX_CONSECUTIVE_LOSSES=2
CONTINUOUS_LEARNING_ENABLED=true
DYNAMIC_THRESHOLDS_ENABLED=true
AUTO_RETRAIN_ENABLED=true
AUTO_RETRAIN_MIN_TRADES=50
AUTO_RETRAIN_INTERVAL_HOURS=24
AUTO_RETRAIN_MIN_WIN_RATE=0.45
AUTO_RETRAIN_MAX_DRAWDOWN=0.15
AUTO_RETRAIN_MIN_MODEL_SCORE=0.55

ENABLE_TELEGRAM_ALERTS=false
TELEGRAM_ENABLED=false
TELEGRAM_PARSE_MODE=HTML
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLL_SECONDS=1

ENABLE_SCHEDULER=true
ENABLE_CONTINUOUS_PIPELINE=true
ENABLE_LIVE_SIMULATED=false
CYCLE_INTERVAL_SECONDS=300
NEWS_REFRESH_INTERVAL_SECONDS=1800
HEARTBEAT_INTERVAL_SECONDS=30
MAX_CONSECUTIVE_ERRORS=5
RETRY_BACKOFF_SECONDS=10

# =========================
# Multi-Agent External LLMs
# =========================
LLM_ENABLE_EXTERNAL=true
LLM_FORCE_LOCAL_FALLBACK=true
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=2
OPENROUTER_API_KEY=your_openrouter_api_key_here
MARKET_AGENT_MODEL=openai/gpt-oss-120b:free
NEWS_AGENT_MODEL=openai/gpt-oss-120b:free
NEWS_AGENT_FALLBACK_MODEL=local-news-heuristic
RISK_AGENT_MODEL=minimax/minimax-m2.5:free
EXECUTION_AGENT_MODEL=minimax/minimax-m2.5:free
MEMORY_AGENT_MODEL=arcee-ai/trinity-large-preview:free
MARKET_AGENT_FALLBACK_MODEL=local-market-heuristic
RISK_AGENT_FALLBACK_MODEL=local-risk-heuristic
EXECUTION_AGENT_FALLBACK_MODEL=local-execution-policy
MEMORY_AGENT_FALLBACK_MODEL=local-memory-engine
MULTI_AGENT_BUY_THRESHOLD=0.66
MULTI_AGENT_SELL_THRESHOLD=0.34
MULTI_AGENT_TRAIN_ON_RUNTIME_CYCLE=true
MULTI_AGENT_APPLY_DYNAMIC_THRESHOLDS_ON_RUNTIME_CYCLE=true
